# ─────────────────────────────────────────────
# DocumentAnalyserAPI – variables de entorno
# Copia este archivo como .env y ajusta los valores
# ─────────────────────────────────────────────

# --- Modo de ejecución ---
# Entorno: "production" o "development"
ENVIRONMENT=development

# --- Base de datos ---
# Desarrollo (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./cbam.db
# Producción (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://cbam_user:${POSTGRES_PASSWORD}@db:5432/cbam_db

# --- PostgreSQL (solo producción) ---
POSTGRES_DB=cbam_db
POSTGRES_USER=cbam_user
POSTGRES_PASSWORD=changeme_in_production

# --- API ---
APP_NAME=DocumentAnalyserAPI
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
